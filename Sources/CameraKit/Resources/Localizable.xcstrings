    "No tenemos permiso para acceder a la cámara o al micrófono. \n\nCambia la configuración en ajustes." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We don't have permission to access the camera or microphone. \n\nChange the configuration in settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No tenemos permiso para acceder a la cámara o al micrófono. \n\nCambia la configuración en ajustes."
          }
        }
      }
    },
    "Acceso a cámara interrumpido. \n\nAlgún proceso de mayor prioridad ha bloqueado el acceso." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera access interrupted. \n\nA higher-priority process has blocked access."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
